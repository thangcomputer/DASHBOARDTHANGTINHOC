# Copy to .env and fill in values. Never commit .env.

NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/quanlycms

# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=30d

CLIENT_URL=http://localhost:5173
FRONTEND_URL=

# Cookie signing (OAuth state). Defaults to JWT_SECRET if unset.
COOKIE_SECRET=

# Behind Nginx / Cloudflare: TRUST_PROXY=1
TRUST_PROXY=1

# JSON body limit (use Multer for large files)
JSON_BODY_LIMIT=1mb

# Tin nháº¯n: file/áº£nh Ä‘Ã­nh kÃ¨m tá»± xÃ³a sau N ngÃ y (máº·c Ä‘á»‹nh 10)
MESSAGE_FILE_RETENTION_DAYS=10

# Optional: Redis — token blacklist + query cache + BullMQ job queue
# Không đặt = in-memory cache + queue inline (dev đơn instance vẫn chạy bình thường)
# REDIS_URL=redis://127.0.0.1:6379

# Zalo OA — gửi OTP / mật khẩu (queue job notify)
# ZALO_OA_TOKEN=
# ZALO_OA_REFRESH_TOKEN=

# AI Center (Phase 11) — OpenAI-compatible (OpenAI / Azure / Ollama...)
# AI_ENABLED=1
# AI_API_KEY=
# AI_BASE_URL=https://api.openai.com/v1
# AI_MODEL=gpt-4o-mini
# AI_TIMEOUT_MS=45000

# Backup (Phase 9) — Super Admin only
# BACKUP_KEEP=7
# BACKUP_SCHEDULE=1
# BACKUP_CRON=0 3 * * *

# SMTP — gửi OTP / mật khẩu / hóa đơn PDF (queue job notify)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=0
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM="Thang Tin Hoc <noreply@example.com>"

# Optional: encrypt session payloads stored in Mongo (production only)
# SESSION_ENCRYPTION_KEY=

# Rate limits (optional overrides)
# RATE_LIMIT_API_MAX=400
# RATE_LIMIT_LOGIN_MAX=25
# RATE_LIMIT_CAPTCHA_MAX=120
# RATE_LIMIT_REFRESH_MAX=200
# RATE_LIMIT_SENSITIVE_MAX=20
# RATE_LIMIT_CHECK_ROLE_MAX=60

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# Zalo OAuth
ZALO_APP_ID=
ZALO_APP_SECRET=
ZALO_CALLBACK_URL=http://localhost:5000/api/auth/zalo/callback

# SePay webhook (required in production â€” fail-closed if unset)
SEPAY_API_KEY=
SEPAY_SECRET_KEY=

# Bank display / QR
BANK_ID=
ACCOUNT_NO=
ACCOUNT_NAME=

LOG_LEVEL=info

# Deploy helper (deploy_scripts/set_zalo_token.cjs â€” never commit secrets)
# DEPLOY_SSH_HOST=
# DEPLOY_SSH_USER=root
# DEPLOY_SSH_PASSWORD=
# DEPLOY_ENV_FILE=/www/wwwroot/quanlycms/.env

# Super Admin fallback when adminPasswordHash not set in DB (required in production if no DB hash)
# MASTER_ADMIN_PASSWORD=

# Super Admin MFA (TOTP): bật qua API sau khi đăng nhập
# POST /api/auth/mfa/setup → POST /api/auth/mfa/enable { code }
# Tắt: POST /api/auth/mfa/disable { password, code }
# VPS deploy scripts (rebuild_frontend.cjs, sync_vps.cjs) — never commit real values
# VPS_HOST=
# VPS_USER=root
# VPS_PASSWORD=
# VPS_SSH_KEY_PATH=
# VPS_APP_DIR=/www/wwwroot/dashboard.giasutinhoc24h.com
